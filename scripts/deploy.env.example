# scripts/deploy.env.example
# このファイルを scripts/deploy.env にコピーして実値を埋める(deploy.env は git 追跡外)。
# 本ファイルは infra プロビジョニング(scripts/deploy.sh)用。
# migrate/seed/publish/E2E は GitHub Actions(main マージ)が担うため、その設定値は
# GitHub の Actions variables/secrets 側に置く(docs/runbooks/deploy.md 参照)。

# --- Azure ---
SUBSCRIPTION_ID=
RG=epcf-rg
LOCATION=japaneast
PREFIX=epcf

# --- SQL 管理者 ---
SQL_ADMIN=epcfadmin
SQL_PASSWORD=            # 16文字以上・英大文字小文字数字記号

# --- Entra External ID (bicep が Auth__* に投入) ---
# External ID テナント作成前は空のままでよい(認証ミドルウェアは fail-closed)。
# 作成後に entra-external-id.md の値を入れて deploy.sh を再実行する。
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_TENANT_CLAIM=
AUTH_METADATA_ADDRESS=
