# scripts/deploy.env.example
# このファイルを scripts/deploy.env にコピーして実値を埋める(deploy.env は git 追跡外)。

# --- Azure ---
SUBSCRIPTION_ID=
RG=epcf-rg
LOCATION=japaneast
PREFIX=epcf

# --- SQL 管理者 ---
SQL_ADMIN=epcfadmin
SQL_PASSWORD=            # 16文字以上・英大文字小文字数字記号

# --- シード / E2E ---
SEED_WEBHOOK_URL=        # 例 https://webhook.site/<uuid>
DEVICE_ID=handy-07
